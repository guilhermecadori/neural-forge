# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# MLflow
mlruns/
mlartifacts/

# DVC — per-project state that must never be committed.
# NOTE: .dvc pointer files (data/**/*.dvc, models/**/*.dvc) MUST be
# committed. Do NOT add a blanket '*.dvc' pattern here.
.dvc/tmp/
.dvc/cache/
.dvc/config.local
.dvc/plots/

# Models (large binaries — use DVC to track)
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx

# Data (track with DVC, not git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Environment variables
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db


# --- baseline (templates/.gitignore-baseline) ---
data/**
!data/**/
!data/**/.gitkeep
!data/**/*.dvc
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
