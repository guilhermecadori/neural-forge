# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.env

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# DVC-tracked: content is never committed, only .dvc pointers / .gitkeep
data/raw/*
data/processed/*
data/final/*
models/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/final/.gitkeep
!models/.gitkeep
!**/*.dvc

# Artifacts: large outputs excluded, structure retained
artifacts/**/*
!artifacts/**/.gitkeep


# --- baseline (templates/.gitignore-baseline) ---
data/
!data/.gitkeep
!data/**/.gitkeep
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
