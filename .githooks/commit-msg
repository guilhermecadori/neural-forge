#!/usr/bin/env sh
# Enforces Conventional Commits locally.
# Enable once per clone with:  git config core.hooksPath .githooks

msg_file="$1"
first_line=$(head -n1 "$msg_file")

# Allow merge / revert / fixup commits to pass through untouched.
case "$first_line" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*|"amend!"*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .{1,}$'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  cat >&2 <<EOF
ERROR: commit message does not follow Conventional Commits.

  Got:      $first_line

  Expected: <type>[optional scope][!]: <description>
  Types:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
  Examples: feat(training): add mixed-precision support
            fix: handle empty config path
            docs: add CONTRIBUTING guide
            refactor(data)!: drop legacy loader (BREAKING CHANGE)

See https://www.conventionalcommits.org/en/v1.0.0/
EOF
  exit 1
fi
